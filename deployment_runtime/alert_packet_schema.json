{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DER Deployment Alert Packet",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "alert_id",
    "timestamp_utc",
    "site_id",
    "packet_source",
    "model_name",
    "model_profile",
    "score",
    "threshold",
    "severity",
    "modality",
    "window_start_utc",
    "window_end_utc",
    "top_features",
    "affected_assets",
    "local_context_path"
  ],
  "properties": {
    "alert_id": {
      "type": "string",
      "minLength": 8
    },
    "timestamp_utc": {
      "type": "string"
    },
    "site_id": {
      "type": "string"
    },
    "packet_source": {
      "type": "string"
    },
    "model_name": {
      "type": "string"
    },
    "model_profile": {
      "type": "string"
    },
    "score": {
      "type": "number"
    },
    "threshold": {
      "type": "number"
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "modality": {
      "type": "string"
    },
    "asset_id": {
      "type": ["string", "null"]
    },
    "affected_assets": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "top_features": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["feature", "signal", "aggregation", "contribution"],
        "properties": {
          "feature": { "type": "string" },
          "signal": { "type": "string" },
          "aggregation": { "type": "string" },
          "contribution": { "type": "number" },
          "window_value": { "type": ["number", "null"] },
          "reference_value": { "type": ["number", "null"] },
          "residual": { "type": ["number", "null"] }
        }
      }
    },
    "window_start_utc": {
      "type": "string"
    },
    "window_end_utc": {
      "type": "string"
    },
    "local_context_path": {
      "type": "string"
    },
    "buffer_id": {
      "type": ["string", "null"]
    },
    "explanation_packet_path": {
      "type": ["string", "null"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
